{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RateLimiting": {
    "GlobalMaxAttempts": "100",
    "GlobalWindowMinutes": "1",
    "EndpointMaxAttempts": "30",
    "EndpointWindowMinutes": "1"
  },
  "Security": {
    "AccountLockout": {
      "MaxFailedAttempts": 5,
      "LockoutDurationMinutes": 15,
      "EnableProgressiveLockout": true,
      "ProgressiveMultiplier": 2,
      "MaxLockoutDurationMinutes": 60
    }
  },
  "RequestLogging": {
    "Enabled": true,
    "DetailedPaths": [],
    "ExcludedPaths": [
      "/health",
      "/openapi"
    ]
  },
  "Https": {
    "Enabled": false,
    "HttpsPort": null,
    "Hsts": {
      "Enabled": false,
      "MaxAgeDays": 365,
      "IncludeSubDomains": true,
      "Preload": false
    }
  },
  "RequestTimeout": {
    "DefaultTimeoutSeconds": 30,
    "Endpoints": [
      {
        "PathPattern": "/api/*/openfoodfacts/*",
        "TimeoutSeconds": 60
      }
    ]
  },
  "GracefulShutdown": {
    "Enabled": true,
    "TimeoutSeconds": 30
  }
}
